        <mxCell id="zQhQzCSvZs7QWjj12YHX-18" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" value="&lt;h2&gt;Key Functions of an OS&lt;/h2&gt;" vertex="1">
