        <mxCell id="zQhQzCSvZs7QWjj12YHX-49" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;" value="&lt;div&gt;&lt;ol&gt;&lt;li&gt;UNIX is Portable and can run o any type of Hardware because it was built on C and C is Portable.&lt;/li&gt;&lt;li&gt;UNIX was NOT Open Surce and Users had to buy Licence. Companies baught UNIX Licence and enhanced it to work best with thier hardware. Examples&lt;/li&gt;&lt;ol&gt;&lt;li&gt;IBM AIX - Advanced Interactive Executive&lt;/li&gt;&lt;li&gt;HP - UX&lt;/li&gt;&lt;li&gt;Sun&amp;nbsp; Micro System - Solaris&lt;/li&gt;&lt;/ol&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="730" x="50" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="zQhQzCSvZs7QWjj12YHX-50" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=bottom;" value="Hierarchial&amp;nbsp;&lt;div&gt;File System&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="120" x="660" y="1280" as="geometry" />
        </mxCell>
        <mxCell id="zQhQzCSvZs7QWjj12YHX-51" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div style=&quot;&quot;&gt;&lt;h2&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Birth of Linux&lt;/span&gt;&lt;/h2&gt;&lt;ol&gt;&lt;li style=&quot;&quot;&gt;in 1991, Linus Torvalds, only 21 years old, launched a Unix Like OS but kept is free and Open Source.&amp;nbsp;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;This OS was reliable, Secure and Portable.&amp;nbsp;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;As this was Open Sourced, it was easier for people to make controlled ammends to it and keep improving it.&amp;nbsp;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;This was mainly Virus Free becasue of it Open source nature, many users could contribute to fixing vulnarablilties&lt;br&gt;&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Same Key Characteristics as UNIX like&lt;/li&gt;&lt;ol&gt;&lt;li style=&quot;&quot;&gt;Multi-Tasking&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Multi User&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Portable&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Kernel - Shell - User Model&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Hierarchical File System&lt;/li&gt;&lt;/ol&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="760" x="40" y="1620" as="geometry" />
        </mxCell>
        <mxCell id="zQhQzCSvZs7QWjj12YHX-52" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;div style=&quot;&quot;&gt;&lt;h2&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Linux Distributions&lt;/span&gt;&lt;/h2&gt;&lt;ol&gt;&lt;li style=&quot;&quot;&gt;Debian --&amp;nbsp;General Purpose, can be used everywhere (including embedded system, stable, oldest)&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Ubuntu --&amp;nbsp;Desktop frieldly distribution. Created on top of Debian. Beginer friendly&lt;/li&gt;&lt;li style=&quot;&quot;&gt;RedHat Enterprise Linux -- RHEL --&amp;nbsp;Enterprised grade distribution. Commercial grade. Paid version&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Fedora -- Cutting edge distribution. Latest sofware and features appear here first. Sponsored by RHEL&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Kali Linux -- Security focused distribution used for testing security. Preloaded with security related features. Mainly used by Ethical Hackers.&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Centos -- Community Linux derived from RHEL. Free version of RHEL.&lt;/li&gt;&lt;li style=&quot;&quot;&gt;Amazon Linux -- Optimized for AWS&lt;/li&gt;&lt;/ol&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="760" x="35" y="1830" as="geometry" />
        </mxCell>
        <mxCell id="zQhQzCSvZs7QWjj12YHX-53" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;h2&gt;Basic Linux Commands&lt;/h2&gt;" vertex="1">
          <mxGeometry height="1060" width="780" x="20" y="2210" as="geometry" />
        </mxCell>
